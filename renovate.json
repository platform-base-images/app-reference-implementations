{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["at any time"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate — Dependency Updates",
  "dependencyDashboardApproval": false,
  "commitMessagePrefix": "chore(deps): ",
  "labels": ["renovate", "dependencies"],
  "ignoreDeps": ["docker/dockerfile"],
  "pinDigests": true,
  "prCreation": "immediate",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Platform base images distroless runtime tags — skip (causes group collision)",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/platform-base-images/**"],
      "matchCurrentValue": "/.+-distroless.*/",
      "enabled": false
    },
    {
      "description": "Platform base images — group all builder-stage updates into one PR",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/platform-base-images/**"],
      "groupName": "platform base images",
      "commitMessageTopic": "platform base images",
      "automerge": false
    },
    {
      "description": "GitHub Actions patch/minor/digest — auto-merge",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "GitHub Actions major — manual review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "npm patch/minor — auto-merge",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "npm major — manual review",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "pip patch/minor — auto-merge",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Maven patch/minor — auto-merge",
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
